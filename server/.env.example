PORT=3001
JWT_SECRET=замените-на-длинный-случайный-секрет-минимум-32-символа
VAPID_PUBLIC=
VAPID_PRIVATE=
CV_ENABLED=true
CV_ATM_THRESHOLD=0.30
CV_ATM_MARGIN=0.12
CV_TIMEOUT_MS=45000
PHOTO_MAX_EDGE=1280
PHOTO_JPEG_QUALITY=82
PHOTO_UPLOAD_MAX_MB=12
